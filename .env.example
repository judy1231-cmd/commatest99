# ============================================================
# 쉼표(,) 환경변수 예시 — 이 파일을 .env로 복사 후 값 입력
# cp .env.example .env
# ============================================================

# ── 로컬 개발 (docker-compose.yml) ──────────────────────────
DB_PASSWORD=comma1234
JWT_SECRET=comma-secret-key-must-be-at-least-256-bits-long-for-hs256
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
CLAUDE_API_KEY=your_claude_api_key

# ── AWS 프로덕션 (docker-compose.prod.yml) ───────────────────
RDS_ENDPOINT=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
RDS_USERNAME=admin
RDS_PASSWORD=your_rds_password
REDIS_HOST=your-elasticache-endpoint.cache.amazonaws.com
DOMAIN=your-domain.com
