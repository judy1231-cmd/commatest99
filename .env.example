# ============================================================
# 쉼표(,) 환경변수 예시 — 이 파일을 .env로 복사 후 값 입력
# cp .env.example .env
# ============================================================

# ── DB 비밀번호 (MySQL 컨테이너 + Spring Boot 공용) ──────────
DB_PASSWORD=comma1234

# ── JWT 시크릿 (32자 이상, 영문+숫자 랜덤) ───────────────────
JWT_SECRET=comma-secret-key-must-be-at-least-256-bits-long-for-hs256

# ── 이메일 인증 (Gmail 앱 비밀번호) ─────────────────────────
# 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── Claude API (진단 기능, 선택) ─────────────────────────────
CLAUDE_API_KEY=your_claude_api_key

# ── 앱 URL (EC2 배포 시 실제 EC2 퍼블릭 IP로 변경) ────────────
APP_BASE_URL=http://localhost:8080
APP_FRONT_URL=http://localhost

# ── Vworld 지도 API 키 (data.go.kr 발급) — frontend/.env에 설정 ─
REACT_APP_VWORLD_KEY=your_vworld_api_key
