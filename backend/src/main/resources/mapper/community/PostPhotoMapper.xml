<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.comma.domain.community.mapper.PostPhotoMapper">

    <insert id="insertPhoto">
        INSERT INTO post_photos (post_id, photo_url)
        VALUES (#{postId}, #{photoUrl})
    </insert>

    <select id="findByPostId" resultType="com.comma.domain.community.model.PostPhoto">
        SELECT id, post_id AS postId, photo_url AS photoUrl, created_at AS createdAt
        FROM post_photos
        WHERE post_id = #{postId}
        ORDER BY id ASC
    </select>

    <delete id="deleteByPostId">
        DELETE FROM post_photos WHERE post_id = #{postId}
    </delete>

</mapper>
