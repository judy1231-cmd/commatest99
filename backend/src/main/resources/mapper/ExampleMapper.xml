<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.comma.mapper.ExampleMapper">

  <resultMap id="ExampleResultMap" type="Example">
    <id property="id" column="id"/>
    <result property="title" column="title"/>
    <result property="content" column="content"/>
    <result property="createdAt" column="created_at"/>
  </resultMap>

  <select id="findAll" resultMap="ExampleResultMap">
    SELECT id, title, content, created_at
    FROM example
    ORDER BY created_at DESC
  </select>

  <select id="findById" parameterType="long" resultMap="ExampleResultMap">
    SELECT id, title, content, created_at
    FROM example
    WHERE id = #{id}
  </select>

  <insert id="insert" parameterType="Example" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO example (title, content, created_at)
    VALUES (#{title}, #{content}, NOW())
  </insert>

  <update id="update" parameterType="Example">
    UPDATE example
    SET title = #{title}, content = #{content}
    WHERE id = #{id}
  </update>

  <delete id="delete" parameterType="long">
    DELETE FROM example WHERE id = #{id}
  </delete>

</mapper>
